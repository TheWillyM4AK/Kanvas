			"y": -710,
			"width": 380,
			"height": 200,
			"color": "1"
		},
		{
			"id": "canvas-warnings",
			"type": "text",
			"text": "## Warnings\n- TE-03 E2E smoke suite is outside all groups",
			"x": -560,
			"y": -490,
			"width": 380,
			"height": 200,
			"color": "3"
		},
		{
			"id": "legend",
			"type": "text",
			"text": "## Legend\n🔴 **Red** = To Do (ready)\n⬜ **Gray** = Blocked\n🟠 **Orange** = Doing\n🔵 **Cyan** = Ready to review\n🟢 **Green** = Done\n🟣 **Purple** = Proposed by agent",
			"x": -560,
			"y": -270,
			"width": 380,
