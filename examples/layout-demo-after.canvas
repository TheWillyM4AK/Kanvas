			"height": 260,
			"label": "Infrastructure"
		},
		{
			"id": "7d8338f8",
			"type": "text",
			"text": "## BA-01 Scaffold API service\nExpress app, routing, middleware, DI container.",
			"x": 2790,
			"y": 510,
			"width": 420,
			"height": 180,
			"color": "6"
		},
		{
			"id": "07ab8fb7",
			"type": "text",
			"text": "## BA-02 Implement authentication\nJWT issue, refresh, revoke. OAuth2 provider integration.",
			"x": 2790,
			"y": 940,
			"width": 420,
			"height": 180,
			"color": "6"
		},
		{
			"id": "97a82d68",
			"type": "text",
			"text": "## BA-03 Implement data endpoints\nCRUD routes with validation and DB transactions.",
			"x": 3280,
			"y": 940,
			"width": 420,
			"height": 180,
			"color": "6"
		},
		{
			"id": "2b3cb6b2",
			"type": "text",
			"text": "## BA-04 Add rate limiting and caching\nRedis-backed throttle and cache layer.",
			"x": 2790,
			"y": 1370,
			"width": 420,
			"height": 180,
			"color": "6"
		},
		{
			"id": "bcd9334c",
			"type": "text",
			"text": "## BA-05 Write API integration tests\nCover all happy paths and error scenarios.",
			"x": 2790,
			"y": 1800,
			"width": 420,
			"height": 180,
			"color": "6"
		},
		{
			"id": "0117cd4f",
			"type": "text",
			"text": "## FR-03 Build main dashboard\nData tables, charts, filter controls, pagination.",
			"x": 4880,
			"y": 1370,
			"width": 420,
			"height": 180,
			"color": "6"
		},
		{
			"id": "97a10319",
			"type": "text",
			"text": "## FR-04 Build settings panel\nUser profile, preferences, notification toggles.",
			"x": 4390,
			"y": 1800,
			"width": 420,
			"height": 180,
			"color": "6"
		},
		{
			"id": "cf4c6ca1",
			"type": "text",
			"text": "## FR-05 Cross-browser testing\nPlaywright suite: Chrome, Firefox, Safari, mobile.",
			"x": 4390,
			"y": 2230,
			"width": 420,
			"height": 180,
			"color": "6"
		},
		{
			"id": "4903dd61",
			"type": "text",
			"text": "## FR-06 Accessibility audit\nWCAG 2.1 AA: automated axe-core + manual review.",
			"x": 4390,
			"y": 2660,
			"width": 420,
			"height": 180,
			"color": "6"
		},
		{
			"id": "b72c86f9",
			"type": "text",
			"text": "## FR-01 Bootstrap SPA\nVite + React, router, global state, design tokens.",
			"x": 4390,
			"y": 510,
			"width": 420,
			"height": 180,
			"color": "6"
		},
		{
			"id": "a181530f",
			"type": "text",
			"text": "## FR-02 Build auth UI\nLogin, logout, token refresh, session timeout flows.",
			"x": 4390,
			"y": 1370,
			"width": 420,
			"height": 180,
			"color": "6"
		},
		{
			"id": "5c0e1796",
			"type": "text",
			"text": "## TE-05 Security scan\nOWASP ZAP on staging, Trivy on container images.",
			"x": 1680,
			"y": 3520,
			"width": 420,
			"height": 180,
			"color": "6"
		},
		{
			"id": "51cb9fa2",
			"type": "text",
			"text": "## TE-01 Define test strategy\nScope, tooling choices, coverage targets per layer.",
			"x": 1190,
			"y": 940,
			"width": 420,
			"height": 180,
			"color": "6"
		},
		{
			"id": "e22dab21",
			"type": "text",
			"text": "## TE-02 API contract tests\nPact broker for Backend-to-Frontend contracts.",
			"x": 1190,
			"y": 1800,
			"width": 420,
			"height": 180,
			"color": "6"
		},
		{
			"id": "967bdeb5",
			"type": "text",
			"text": "## TE-04 Performance baseline\nk6 load test, capture p50/p95/p99 metrics.",
			"x": 1190,
			"y": 3520,
			"width": 420,
			"height": 180,
			"color": "6"
		},
		{
			"id": "9315d615",
			"type": "text",
			"text": "## TE-03 E2E smoke suite\nCritical user paths executed against staging.",
			"x": 1190,
			"y": 3090,
			"width": 420,
			"height": 180,
			"color": "6"
		},
		{
			"id": "a11fb8f2",
			"type": "text",
			"text": "## DO-01 Write architecture decision records\nDocument key technology and design choices as ADRs.",
			"x": 1190,
			"y": 80,
			"width": 420,
			"height": 180,
			"color": "6"
		},
		{
			"id": "7d541c1c",
			"type": "text",
			"text": "## DO-02 API reference docs\nOpenAPI â†’ Redoc pipeline, hosted on internal portal.",
			"x": 1680,
			"y": 80,
			"width": 420,
			"height": 180,
			"color": "6"
		},
		{
			"id": "185c085d",
			"type": "text",
			"text": "## DO-03 Runbook: on-call guide\nIncident playbooks, escalation paths, war-room checklist.",
			"x": 2170,
			"y": 80,
			"width": 420,
			"height": 180,
			"color": "6"
		},
		{
			"id": "1019ad8c",
			"type": "text",
			"text": "## DO-04 Changelog and release notes\nKeep-a-changelog format, semver tagging procedure.",
			"x": 1190,
			"y": 510,
			"width": 420,
			"height": 180,
			"color": "6"
		},
		{
			"id": "8538e016",
			"type": "text",
			"text": "## AN-01 Define KPI taxonomy\nMetric names, dimensions, owners, SLO targets.",
			"x": 80,
			"y": 80,
			"width": 420,
			"height": 180,
			"color": "6"
		},
		{
			"id": "3897147d",
			"type": "text",
			"text": "## AN-05 Set up alerting rules\nPagerDuty integration, anomaly detection, thresholds.",
			"x": 80,
			"y": 1370,
			"width": 420,
			"height": 180,
			"color": "6"
		},
		{
			"id": "e5e05c29",
			"type": "text",
			"text": "## AN-02 Instrument frontend events\nSegment.io calls on all key user interactions.",
			"x": 80,
			"y": 510,
			"width": 420,
			"height": 180,
			"color": "6"
		},
		{
			"id": "8756ad51",
			"type": "text",
			"text": "## AN-03 Build data pipeline\nKafka â†’ Flink â†’ ClickHouse ETL, schema registry.",
			"x": 570,
			"y": 510,
			"width": 420,
			"height": 180,
			"color": "6"
		},
		{
			"id": "1c814d7c",
			"type": "text",
			"text": "## AN-04 Create Grafana dashboards\nDAU, retention, funnel, and performance boards.",
			"x": 80,
			"y": 940,
			"width": 420,
			"height": 180,
			"color": "6"
		},
		{
			"id": "7ad90d8c",
			"type": "text",
			"text": "## DE-01 Containerise services\nDockerfiles, multi-stage builds, compose for local dev.",
			"x": 80,
			"y": 2660,
			"width": 420,
			"height": 180,
			"color": "6"
		},
		{
			"id": "c0a75156",
			"type": "text",
			"text": "## DE-02 Write Helm charts\nK8s manifests, values.yaml, secrets integration.",
			"x": 80,
			"y": 3090,
			"width": 420,
			"height": 180,
			"color": "6"
		},
		{
			"id": "fa44babc",
			"type": "text",
			"text": "## DE-03 Set up CI pipeline\nGHA: lint â†’ test â†’ build â†’ push â†’ deploy stages.",
			"x": 80,
			"y": 3520,
			"width": 420,
			"height": 180,
			"color": "6"
		},
		{
			"id": "39c077dc",
			"type": "text",
			"text": "## DE-04 Canary rollout procedure\nArgo Rollouts config, analysis templates, rollback plan.",
			"x": 80,
			"y": 3950,
			"width": 420,
			"height": 180,
			"color": "6"
		},
		{
			"id": "45b54e0b",
			"type": "text",
			"text": "## IN-01 Provision cloud environment\nVPC, subnets, NAT gateway, security groups.",
			"x": 5485,
			"y": 80,
			"width": 420,
			"height": 180,
			"color": "6"
		},
		{
			"id": "b720eb7c",
			"type": "text",
			"text": "## IN-02 Set up DNS and load balancer\nRoute53 records, ALB target groups, health checks.",
			"x": 2790,
			"y": 80,
			"width": 420,
			"height": 180,
			"color": "6"
		},
		{
			"id": "fe206717",
			"type": "text",
			"text": "## IN-03 Bootstrap secrets manager\nVault init, policies, auth backends, secret rotation.",
			"x": 5975,
			"y": 80,
			"width": 420,
			"height": 180,
			"color": "6"
		},
		{
			"id": "canvas-errors",
